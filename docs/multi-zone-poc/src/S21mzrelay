#!/bin/sh
# S21mzrelay — multi-zone side-car autostart (PoC P4.2).
# rcS invokes S* scripts with no argument -> default to start.
# Guarded + backgrounded: never blocks or fails the boot sequence.
BIN=/opt/mzrelay3
CONF=/opt/mzrelay.conf
# P5: CONF now holds mzrelay3 args: <dst_grp> <dst_port> <ttl> <ifaddr> <silence_ms> <rest_port> [zones.json]
# zone table itself lives in /opt/mzzones.json (managed via REST, not CONF)
case "${1:-start}" in
start)
	[ -x "$BIN" ] && [ -f "$CONF" ] || exit 0
	(
		n=0
		while [ $n -lt 30 ]; do
			ifconfig eth0 2>/dev/null | grep -q "inet addr" && break
			sleep 1; n=$((n+1))
		done
		exec "$BIN" $(cat "$CONF") 2>>/tmp/mzrelay.boot.log
	) &
	echo "mzrelay3: autostart armed"
	;;
stop)
	killall mzrelay3 2>/dev/null
	;;
esac
exit 0
