+/* P7: zones route token check. Comparison logic and error JSON body copied
+ * verbatim from request_verify_token_cmd (incl. len == strlen(now_token) - 1
+ * off-by-one quirk and A002/A003 codes). Difference: this is an auth gate --
+ * success returns 0 (no reply; zones handler forwards), failure sends the error
+ * reply then returns -1, with HTTP status 401 instead of the legacy 200 (zones
+ * is a new authenticated API using real HTTP status codes, consistent with 503). */
+static int mzweb_check_token(void* client, void* http_head)
+{
+	char* code = NULL;
+	char* msg = NULL;
+	char* value = NULL;
+	int len = 0;
+	get_http_head(http_head, "Authorization", &value, &len);
+
+	if (len > 7)
+	{
+		len -= 7;
+		value += strlen("Bearer ");
+		if (len == (strlen(s_http_sip_set->now_token) - 1) &&
+			strncmp(value, s_http_sip_set->now_token, len) == 0)
+		{
+			if (s_http_sip_set->now_token_timestamp + TOKEN_EXPIRES_MAX_SECONDS*1000
+				<= get_main_event_loop()->mn_now)
+			{
+				memset(s_http_sip_set->now_token, 0, 64);
+				s_http_sip_set->now_token_timestamp = 0;
+
+				code = "A002";
+				msg = "Token已过期";
+			}
+			else
+			{
+				s_http_sip_set->now_token_timestamp = get_main_event_loop()->mn_now;
+			}
+		}
+		else
+		{
+			code = "A003";
+			msg = "该Token非当前有效Token";
+		}
+	}
+	else
+	{
+		code = "A003";
+		msg = "没有Token信息";
+	}
+
+	if (msg == NULL && code == NULL)
+	{
+		return 0;
+	}
+
+	char http_msg[512] = {0};
+	snprintf(http_msg, 512, "{\"status\": \"error\",\"message\": \"操作失敗\","
+		"\"error_code\": \"%s\",  \"details\": \"%s\"}",
+		code, msg);
+	char buffer[1024] = {0};
+	len = snprintf(buffer, 1024, "HTTP/1.1 401 Unauthorized\r\n"
+							 "Server: %s\r\n"
+							 "Connection: close\r\n"
+							 "Content-Type: application/json;charset=GBK\r\n"
+							 "Content-Length: %d\r\n"
+							 "Allow: %s\r\n\r\n%s",
+							 HBI_WEB_SERVER,
+							 strlen(http_msg),
+							 HBI_WEB_METHOD,
+							 http_msg);
+	web_snd_data(client, buffer, len);
+	return -1;
+}
