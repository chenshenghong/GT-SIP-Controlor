+ * pressure; the original stack-buffer version could not fail this way. Both
+ * heap paths below must check for NULL before strlen()/snprintf() dereference it.
+ * This fallback itself uses only stack buffers so it cannot fail the same way. */
+static void mzweb_send_alloc_failure(void* client)
+{
+	char http_msg[64] = {0};
+	snprintf(http_msg, sizeof(http_msg), "{\"status\": \"error\", \"message\": \"out of memory\"}");
+	char buffer[256] = {0};
+	int len = snprintf(buffer, sizeof(buffer), "HTTP/1.1 500 Internal Server Error\r\n"
+							 "Server: %s\r\n"
+							 "Connection: close\r\n"
+							 "Content-Type: application/json;charset=GBK\r\n"
+							 "Content-Length: %d\r\n"
+							 "Allow: %s\r\n\r\n%s",
+							 HBI_WEB_SERVER,
+							 (int)strlen(http_msg),
+							 HBI_WEB_METHOD,
+							 http_msg);
+	web_snd_data(client, buffer, len);
+}
