{
  "name": "sip-cms",
  "version": "1.0.0",
  "description": "SIP 設備中央管理系統 (CMS) — Electron + Vue 3",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "test": "jest --runInBand",
    "build:win": "electron-vite build && electron-builder --win --x64 --dir",
    "build:linux": "electron-vite build && electron-builder --linux --x64 --dir"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "axios": "^1.7.0",
    "iconv-lite": "^0.7.3",
    "pinia": "^2.2.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "autoprefixer": "^10.4.0",
    "electron": "^41.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "jest": "^29.7.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.4.11",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
